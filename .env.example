DEYE_API_BASE_URL=https://eu1-developer.deyecloud.com/v1.0
DEYE_APP_ID=
DEYE_APP_SECRET=
DEYE_API_KEY=
DEYE_USERNAME=
DEYE_EMAIL=
DEYE_PASSWORD=
DEYE_COMPANY_ID=0
DEYE_STATION_ID=
DEYE_DEVICE_ID=
DEYE_LOGGER_SN=

# CCTV (HLS stream URL — see docs/CCTV_SETUP.md)
NEXT_PUBLIC_CCTV_HLS_URL=

# Weather forecast (Open-Meteo, free, no API key needed)
# Defaults to 13.6448, 100.7061 if unset.
WEATHER_LAT=13.644809
WEATHER_LON=100.706098

# Telegram alerts — see docs/SOLAR_ALERTS.md
# Cron runs every 30 min during daylight (Bangkok 07:30–16:30 by default)
# and sends a status update with ▲/▼ indicator vs threshold.
# TIME_START/END accept "HH:MM" or plain "H" (e.g. "9" = 09:00).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CRON_SECRET=
SOLAR_ALERT_THRESHOLD_KW=4.0
SOLAR_ALERT_TIME_START=07:30
SOLAR_ALERT_TIME_END=16:30
